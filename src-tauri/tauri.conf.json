{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickBind",
  "version": "1.1.0",
  "identifier": "com.quickbind.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5175",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QuickBind",
        "width": 900,
        "height": 580,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "transparent": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "category": "Utility",
    "shortDescription": "Fast global shortcuts for Windows",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
