  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run renderer:dev\" \"npm run electron:dev\"",
    "renderer:dev": "npm --prefix renderer run dev -- --port 5173 --strictPort",
    "electron:dev": "wait-on tcp:5173 && electron .",
    "renderer:build": "npm run build --prefix renderer",
    "build": "npm run renderer:build && electron-builder"
  },
