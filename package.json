  "type": "commonjs",
  "dependencies": {
    "electron": "^41.3.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.3"
  }
}
